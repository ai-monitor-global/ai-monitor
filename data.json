    "infra_invest": [
      {
        "layer": "Model Router / AI 网关层（按任务路由不同模型）",
        "thesis": "企业普遍采用多模型策略，路由层把单次 API 调用动态分发到成本最优或性能最优的模型，避免厂商锁定并控成本——这是从单模型走向多模型生产架构的刚需。但要注意：当前纯路由/代理类厂商市场份额仍很小（Q4 2025 OpenRouter 占比不足 1%），变现与护城河尚未证明，属高增长但结构未定的早期机会。",
        "players": [
          "OpenRouter",
          "Together AI",
          "Fireworks AI"
        ],
        "summary": "OpenRouter 于 2026 年 5 月 26 日完成 1.13 亿美元 B 轮（CapitalG 领投，NVIDIA、ServiceNow、Snowflake、Databricks 等战投跟投），估值约 13 亿美元、11 个月翻倍以上，周 token 量半年内从 5 万亿增至 25 万亿。F5 报告显示 78% 组织自营推理、平均同时评估/运行 7 个模型；IDC 预测到 2028 年 70% 领先 AI 企业将用多模型路由架构。研究观察、非投资建议。",
        "source": "TechTimes / Ramp（综合）",
        "url": "https://www.techtimes.com/articles/317353/20260529/ai-gateway-openrouter-raises-113m-google-nvidia-route-between-their-models.htm"
      },
      {
        "layer": "AI Agent 编排 / 执行控制层（control plane）",
        "thesis": "资金正从应用 wrapper 转向多 agent 编排引擎、企业级安全层与跨平台互操作框架——即企业把 AI 从试点推向生产前所需的编排、治理、可观测层。投资人奖励可量化的工作流替代与执行基础设施，而对泛用 agent 壳和无明确风控故事的广义自主性失去耐心；资本高度集中在少数核心平台，长尾 wrapper 面临跑道紧张与并购出清。",
        "players": [
          "Orkes",
          "LangGraph (LangChain)",
          "AWS Bedrock AgentCore",
          "Salesforce Agentforce"
        ],
        "summary": "Orkes（由 Netflix 微服务编排架构原班人马打造、维护开源 Conductor）于 4 月获 6000 万美元 B 轮，定位生产级可靠性、可观测与治理的执行层，已服务 3000+ 企业（含 LinkedIn、Quest Diagnostics、Twilio）。投融资数据显示 Agent 开发平台类别 2026 年初回暖（截至 5 月约 1.24 亿美元/5 笔），但 NewMarketPitch 指市场已过纯实验期、结构未定。研究观察、非投资建议。",
        "source": "Pulse2 / Crunchbase / NewMarketPitch（综合）",
        "url": "https://pulse2.com/orkes-60-million-raised-for-ai-orchestration-platform-scaling-enterprise-agent-deployments/"
      },
      {
        "layer": "Agent 运行时治理 / 安全沙箱层",
        "thesis": "几乎所有现成 agent 框架都缺少运行时治理——能用任意模型搭出有能力的 agent，但要在满足合规团队要求的前提下治理它运行时能做什么、不能碰什么、什么需要人工批准，是另一类问题。这正成为企业从试点到生产的卡点，硬件与平台厂商正把它内置（NVIDIA 在 Computex 发布安全运行时）。属于尚未充分定价的控制点机会。",
        "players": [
          "NVIDIA (NemoClaw / OpenShell 安全运行时)",
          "Pegasystems (结构化工作流+人工监督)",
          "Databricks (评估/治理/领域接地)"
        ],
        "summary": "NVIDIA 在 Computex 2026 一次发布六款 agent 产品，其中包含沙箱化安全运行时，让企业定义 agent 允许做什么、不能触碰什么、什么需人工批准——被指是多数 agent 框架完全缺失的一环。这与 Pega、Databricks 把治理/可控自主作为卖点的方向一致，反映买方对象已成熟到要求 agent 在生产中可存活、可审计。研究观察、非投资建议。",
        "source": "Beam.ai（基于 NVIDIA Computex 披露）",
        "url": "https://beam.ai/agentic-insights/nvidia-computex-2026-ai-agent-announcements-enterprise"
